{
  "manifest_version": 3,
  "name": "Nodal Point Command Deck",
  "version": "0.1.0",
  "description": "Side-panel CRM capture, note logging, and Twilio calling for Nodal Point.",
  "permissions": [
    "activeTab",
    "alarms",
    "microphone",
    "notifications",
    "offscreen",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Nodal Point Command Deck",
    "default_icon": {
      "16": "nodalpoint-webicon.png",
      "32": "nodalpoint-webicon.png",
      "48": "nodalpoint-webicon.png",
      "128": "nodalpoint-webicon.png"
    }
  },
  "icons": {
    "128": "nodalpoint-webicon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
