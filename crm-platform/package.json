{
  "name": "crm-platform",
  "version": "0.1.4",
  "private": true,
  "description": "Nodal Point CRM desktop shell",
  "author": "Nodal Point",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build --webpack",
    "build:extension": "node extension/build.mjs",
    "build:turbo": "next build --turbo",
    "build:safe": "npm run typecheck && next build --webpack",
    "generate:favicon-ico": "node scripts/generate-favicon-ico.mjs",
    "validate:gemini-cards": "node scripts/validate-gemini-card-fixtures.mjs",
    "mcp:apollo": "node src/mcp-server/apollo.js",
    "mcp:supabase": "node src/mcp-server/supabase.js",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "next build --webpack",
    "desktop:dev": "concurrently -k \"npm run dev:turbo\" \"wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000/network electron .\"",
    "desktop:prod": "cross-env ELECTRON_START_URL=https://www.nodalpoint.io/network electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder",
    "desktop:publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/search-js-react": "^1.5.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/components": "^1.0.7",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-query-persist-client": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.22",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@twilio/voice-sdk": "^2.18.0",
    "@types/react-pdf": "^6.2.0",
    "@xyflow/react": "^12.10.0",
    "algoliasearch": "^4.20.0",
    "bull": "^4.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "formdata-node": "^6.0.3",
    "formidable": "^3.5.1",
    "framer-motion": "^12.29.0",
    "idb-keyval": "^6.2.2",
    "juice": "^10.0.0",
    "lucide-react": "^0.562.0",
    "mailparser": "^3.6.5",
    "mapbox-gl": "^3.18.1",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "^5.2.8",
    "react-hook-form": "^7.71.1",
    "react-map-gl": "^8.1.0",
    "react-pdf": "^10.4.1",
    "react-rnd": "^10.5.2",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.7.0",
    "sanitize-html": "^2.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "twilio": "^4.19.0",
    "use-sound": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "io.nodalpoint.crm",
    "productName": "Nodal Point CRM",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "public/favicon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "powerchoosers",
        "repo": "power-choosers-crm",
        "releaseType": "release"
      }
    ],
    "afterPack": "scripts/after-pack.mjs",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    }
  }
}
